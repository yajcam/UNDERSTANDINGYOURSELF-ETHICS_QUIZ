<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GEC Study Notes | Understanding the Self & Ethics</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap');

  :root {
    --bg: #0f0e17;
    --surface: #1a1928;
    --surface2: #242338;
    --surface3: #2e2c47;
    --accent1: #e8c547;
    --accent2: #ff6b6b;
    --accent3: #7ec8e3;
    --accent4: #a8e6cf;
    --text: #fffffe;
    --text-muted: #a7a9be;
    --text-dim: #6b6d8a;
    --border: #2e2c47;
    --sidebar-w: 300px;
    --radius: 12px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.8;
    overflow-x: hidden;
  }

  /* ── SIDEBAR ── */
  #sidebar {
    position: fixed;
    top: 0; left: 0;
    width: var(--sidebar-w);
    height: 100vh;
    background: var(--surface);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    z-index: 100;
    transition: transform .3s ease;
    display: flex;
    flex-direction: column;
  }
  #sidebar::-webkit-scrollbar { width: 4px; }
  #sidebar::-webkit-scrollbar-track { background: transparent; }
  #sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .sidebar-header {
    padding: 28px 22px 20px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .sidebar-header .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent1);
    letter-spacing: .5px;
  }
  .sidebar-header .subtitle {
    font-size: .72rem;
    color: var(--text-dim);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .nav-section {
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .nav-section-label {
    padding: 10px 22px 4px;
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-dim);
    font-weight: 500;
  }
  .nav-link {
    display: block;
    padding: 7px 22px;
    font-size: .82rem;
    color: var(--text-muted);
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: all .2s;
    line-height: 1.4;
  }
  .nav-link:hover, .nav-link.active {
    color: var(--text);
    border-left-color: var(--accent1);
    background: rgba(232,197,71,.06);
    padding-left: 28px;
  }
  .nav-link.chapter {
    font-weight: 600;
    color: var(--text);
    font-size: .85rem;
    padding-top: 10px;
  }
  .nav-link.sub { padding-left: 34px; font-size: .78rem; }
  .nav-link.sub:hover { padding-left: 40px; }

  /* ── TOPBAR ── */
  #topbar {
    position: fixed;
    top: 0;
    left: var(--sidebar-w);
    right: 0;
    height: 56px;
    background: rgba(15,14,23,.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    z-index: 90;
  }
  .topbar-title {
    font-size: .9rem;
    color: var(--text-muted);
    font-weight: 400;
  }
  .topbar-pills {
    display: flex;
    gap: 8px;
  }
  .pill {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .5px;
    text-transform: uppercase;
  }
  .pill-self { background: rgba(232,197,71,.15); color: var(--accent1); border: 1px solid rgba(232,197,71,.3); }
  .pill-ethics { background: rgba(255,107,107,.15); color: var(--accent2); border: 1px solid rgba(255,107,107,.3); }

  /* ── MAIN CONTENT ── */
  #main {
    margin-left: var(--sidebar-w);
    padding-top: 56px;
    min-height: 100vh;
  }

  /* ── HERO ── */
  .hero {
    padding: 80px 60px 60px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(232,197,71,.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: -50px; left: 200px;
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(255,107,107,.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-kicker {
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--accent1);
    font-weight: 500;
    margin-bottom: 16px;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 20px;
  }
  .hero h1 span { color: var(--accent1); }
  .hero p {
    max-width: 600px;
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 32px;
  }
  .hero-tags {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .hero-tag {
    padding: 6px 16px;
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: .78rem;
    color: var(--text-muted);
  }

  /* ── CONTENT WRAPPER ── */
  .content {
    max-width: 900px;
    padding: 0 60px 100px;
  }

  /* ── CHAPTER DIVIDER ── */
  .chapter-block {
    margin-bottom: 64px;
  }
  .chapter-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 32px;
    padding: 32px;
    background: var(--surface);
    border-radius: var(--radius);
    border-left: 4px solid var(--accent1);
    position: relative;
    overflow: hidden;
  }
  .chapter-header.ethics-chapter { border-left-color: var(--accent2); }
  .chapter-header::before {
    content: attr(data-num);
    position: absolute;
    right: 24px; top: 16px;
    font-family: 'Playfair Display', serif;
    font-size: 5rem;
    font-weight: 900;
    color: rgba(255,255,255,.04);
    line-height: 1;
  }
  .chapter-num {
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--accent1);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .ethics-chapter .chapter-num { color: var(--accent2); }
  .chapter-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1.2;
  }

  /* ── SECTION ── */
  .section {
    margin-bottom: 40px;
    background: var(--surface);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .section-toggle {
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    padding: 22px 28px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text);
    transition: background .2s;
  }
  .section-toggle:hover { background: var(--surface2); }
  .section-toggle h3 {
    font-size: 1.05rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-icon {
    width: 28px; height: 28px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .85rem;
    flex-shrink: 0;
  }
  .icon-self { background: rgba(232,197,71,.15); color: var(--accent1); }
  .icon-ethics { background: rgba(255,107,107,.15); color: var(--accent2); }
  .icon-blue { background: rgba(126,200,227,.15); color: var(--accent3); }
  .icon-green { background: rgba(168,230,207,.15); color: var(--accent4); }
  .chevron {
    font-size: .8rem;
    color: var(--text-dim);
    transition: transform .3s;
  }
  .section-toggle.open .chevron { transform: rotate(180deg); }
  .section-body {
    display: none;
    padding: 0 28px 28px;
    border-top: 1px solid var(--border);
  }
  .section-body.open { display: block; }

  /* ── TYPOGRAPHY ── */
  .section-body h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: var(--accent1);
    margin: 24px 0 10px;
    font-weight: 700;
  }
  .section-body h4.ethics-h { color: var(--accent2); }
  .section-body h4.blue-h { color: var(--accent3); }
  .section-body h4.green-h { color: var(--accent4); }

  .section-body h5 {
    font-size: .95rem;
    font-weight: 600;
    color: var(--text);
    margin: 16px 0 6px;
  }
  .section-body p {
    color: var(--text-muted);
    margin-bottom: 12px;
    font-size: .93rem;
  }

  /* ── TERM ── */
  .term {
    color: var(--accent1);
    font-weight: 600;
    border-bottom: 1px dashed rgba(232,197,71,.4);
  }
  .term.ethics-t { color: var(--accent2); border-bottom-color: rgba(255,107,107,.4); }
  .term.blue-t { color: var(--accent3); border-bottom-color: rgba(126,200,227,.4); }

  /* ── CALLOUT BOXES ── */
  .callout {
    border-radius: 8px;
    padding: 16px 20px;
    margin: 16px 0;
    font-size: .9rem;
  }
  .callout-def {
    background: rgba(232,197,71,.07);
    border-left: 3px solid var(--accent1);
  }
  .callout-example {
    background: rgba(126,200,227,.07);
    border-left: 3px solid var(--accent3);
  }
  .callout-example .callout-label { color: var(--accent3); }
  .callout-warning {
    background: rgba(255,107,107,.07);
    border-left: 3px solid var(--accent2);
  }
  .callout-warning .callout-label { color: var(--accent2); }
  .callout-tip {
    background: rgba(168,230,207,.07);
    border-left: 3px solid var(--accent4);
  }
  .callout-tip .callout-label { color: var(--accent4); }
  .callout-label {
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 700;
    color: var(--accent1);
    margin-bottom: 6px;
  }
  .callout p { color: var(--text-muted); margin: 0; }

  /* ── LISTS ── */
  .styled-list {
    list-style: none;
    margin: 10px 0;
  }
  .styled-list li {
    color: var(--text-muted);
    font-size: .92rem;
    padding: 5px 0 5px 20px;
    position: relative;
  }
  .styled-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent1);
    font-size: .75rem;
    top: 8px;
  }
  .styled-list.ethics-list li::before { color: var(--accent2); }
  .styled-list.blue-list li::before { color: var(--accent3); }

  /* ── COMPARISON TABLE ── */
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0;
    font-size: .85rem;
  }
  .compare-table th {
    background: var(--surface2);
    color: var(--accent1);
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
    letter-spacing: .5px;
  }
  .compare-table td {
    padding: 9px 14px;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    vertical-align: top;
  }
  .compare-table tr:last-child td { border-bottom: none; }
  .compare-table tr:hover td { background: rgba(255,255,255,.02); }

  /* ── THEORY CARD ── */
  .theory-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
    margin: 16px 0;
  }
  .theory-card {
    background: var(--surface2);
    border-radius: 10px;
    padding: 16px;
    border: 1px solid var(--border);
    transition: border-color .2s, transform .2s;
  }
  .theory-card:hover { border-color: var(--accent1); transform: translateY(-2px); }
  .theory-card.ethics-card:hover { border-color: var(--accent2); }
  .theory-card h5 {
    font-size: .88rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
  }
  .theory-card p {
    font-size: .78rem;
    color: var(--text-dim);
    margin: 0;
    line-height: 1.5;
  }
  .theory-card .thinker {
    font-size: .7rem;
    color: var(--accent1);
    font-weight: 600;
    margin-top: 8px;
    display: block;
  }
  .ethics-card .thinker { color: var(--accent2); }

  /* ── KEY TAKEAWAYS ── */
  .takeaways {
    background: linear-gradient(135deg, rgba(232,197,71,.08), rgba(232,197,71,.03));
    border: 1px solid rgba(232,197,71,.2);
    border-radius: 10px;
    padding: 20px 24px;
    margin-top: 24px;
  }
  .takeaways.ethics-take {
    background: linear-gradient(135deg, rgba(255,107,107,.08), rgba(255,107,107,.03));
    border-color: rgba(255,107,107,.2);
  }
  .takeaways-label {
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
    color: var(--accent1);
    margin-bottom: 12px;
  }
  .ethics-take .takeaways-label { color: var(--accent2); }
  .takeaways ul { list-style: none; }
  .takeaways ul li {
    font-size: .88rem;
    color: var(--text-muted);
    padding: 4px 0 4px 18px;
    position: relative;
  }
  .takeaways ul li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent1);
    font-weight: 700;
    font-size: .8rem;
  }
  .ethics-take ul li::before { color: var(--accent2); }

  /* ── PRACTICE Q ── */
  .pq-block {
    margin: 16px 0;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .pq-question {
    background: var(--surface2);
    padding: 14px 18px;
    font-size: .88rem;
    color: var(--text);
    cursor: pointer;
    display: flex;
    gap: 10px;
    align-items: flex-start;
    transition: background .2s;
  }
  .pq-question:hover { background: var(--surface3); }
  .pq-num {
    background: var(--accent1);
    color: var(--bg);
    border-radius: 4px;
    padding: 1px 7px;
    font-size: .7rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .pq-num.ethics-num { background: var(--accent2); }
  .pq-answer {
    display: none;
    padding: 14px 18px;
    background: var(--surface);
    font-size: .85rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
  }
  .pq-answer.show { display: block; }
  .pq-answer-label {
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent4);
    font-weight: 700;
    margin-bottom: 6px;
  }

  /* ── CODE / FORMULA ── */
  .formula {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 18px;
    font-family: 'DM Mono', monospace;
    font-size: .85rem;
    color: var(--accent3);
    margin: 12px 0;
    overflow-x: auto;
  }

  /* ── PROGRESS BAR ── */
  .progress-section {
    padding: 28px 60px;
    border-bottom: 1px solid var(--border);
  }
  .progress-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }
  .progress-item { }
  .progress-label {
    font-size: .75rem;
    color: var(--text-muted);
    margin-bottom: 6px;
    display: flex;
    justify-content: space-between;
  }
  .progress-bar-bg {
    height: 4px;
    background: var(--surface2);
    border-radius: 2px;
    overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--accent1);
    transition: width 1s ease;
  }
  .progress-bar-fill.ethics-fill { background: var(--accent2); }

  /* ── QUOTE ── */
  .philosopher-quote {
    margin: 20px 0;
    padding: 20px 24px;
    border-left: 3px solid var(--accent3);
    background: rgba(126,200,227,.05);
    border-radius: 0 8px 8px 0;
  }
  .philosopher-quote p {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1rem;
    color: var(--text);
    margin-bottom: 8px;
  }
  .quote-attr {
    font-size: .75rem;
    color: var(--accent3);
    font-weight: 600;
    letter-spacing: .5px;
  }

  /* ── MOBILE TOGGLE ── */
  #menu-toggle {
    display: none;
    position: fixed;
    bottom: 24px; right: 24px;
    width: 52px; height: 52px;
    border-radius: 50%;
    background: var(--accent1);
    color: var(--bg);
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    z-index: 200;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(232,197,71,.4);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    :root { --sidebar-w: 260px; }
    .content, .hero, .progress-section { padding-left: 28px; padding-right: 28px; }
  }
  @media (max-width: 700px) {
    #sidebar { transform: translateX(-100%); }
    #sidebar.open { transform: translateX(0); }
    #topbar { left: 0; }
    #main { margin-left: 0; }
    #menu-toggle { display: flex; }
    .hero h1 { font-size: 2rem; }
    .content { padding-left: 20px; padding-right: 20px; }
    .hero { padding: 40px 20px 30px; }
  }
</style>
</head>
